# ─── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
RUST_LOG=info,restaurant_backend=debug

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
SQLX_OFFLINE=true

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_64
JWT_ISSUER=restaurant-backend
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@yourapp.com
ADMIN_JWT_SECRET=CHANGE_ME_random_32_chars_min
ADMIN_PASSWORD_HASH=

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── Stripe (Test Mode) ───────────────────────────────────────────────────────
# Keys: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Webhook secret: https://dashboard.stripe.com/test/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs: https://dashboard.stripe.com/test/products
STRIPE_PRICE_ACTIONS_20=price_...
STRIPE_PRICE_ACTIONS_100=price_...
STRIPE_PRICE_ACTIONS_500=price_...
STRIPE_SUCCESS_URL=https://dima-fomin.pl/en/billing/success
STRIPE_CANCEL_URL=https://dima-fomin.pl/en/billing/cancel

# ─── Gemini AI ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIza...

# ─── Cloudflare R2 ────────────────────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=product-images
CLOUDFLARE_R2_PUBLIC_URL=https://pub-xxx.r2.dev
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30

# Logging
RUST_LOG=info,restaurant_backend=debug

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
