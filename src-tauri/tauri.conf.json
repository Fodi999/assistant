{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Chef Admin",
  "version": "0.1.0",
  "identifier": "com.chefos.admin",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:3001",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Chef Admin",
        "width": 1540,
        "height": 960,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
